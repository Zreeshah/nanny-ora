// Prisma Schema for NannyOra
// Using SQLite for local dev, easily switchable to PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// User & Auth
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("PARENT") // PARENT, NANNY, ADMIN
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  parentProfile  ParentProfile?
  nannyProfile   NannyProfile?
  jobPosts       JobPost[]
  enquiriesSent  Enquiry[]      @relation("EnquiriesSent")
  reviewsGiven   Review[]       @relation("ReviewsGiven")

  @@map("users")
}

// ============================================================
// Parent Profile
// ============================================================

model ParentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  suburb         String
  childAgeRange  String   // JSON array stored as string
  careTypeNeeded String   // JSON array stored as string
  preferredDays  String
  startDate      String?
  specialistNeeds String  @default("")
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("parent_profiles")
}

// ============================================================
// Nanny Profile
// ============================================================

model NannyProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  suburb                 String
  areasCovered           String   // JSON array stored as string
  yearsExperience        Int
  careTypes              String   // JSON array stored as string
  qualifications         String   @default("") // JSON array stored as string
  eceExperience          Boolean  @default(false)
  neurodiverseExperience Boolean  @default(false)
  firstAidCurrent        Boolean  @default(false)
  driverLicence          Boolean  @default(false)
  hourlyRate             Int
  bio                    String
  availabilitySummary    String   @default("")
  availability           String   @default("[]") // JSON array stored as string
  specialistTags         String   @default("[]") // JSON array stored as string
  verificationLevel      String   @default("LISTED") // LISTED, VERIFIED, PREMIUM_VETTED, SPECIALIST
  adminStatus            String   @default("SUBMITTED") // DRAFT, SUBMITTED, UNDER_REVIEW, APPROVED, VERIFIED, SPECIALIST, SUSPENDED, ARCHIVED
  profileImageUrl        String?

  // Referee structured data (JSON array of {name, phone, email, relationship})
  refereeData            String   @default("[]")

  // --- 7 Safety Vetting Check Statuses ---
  // Values: NOT_STARTED, SUBMITTED, VERIFIED, REJECTED
  identityVerified       String   @default("NOT_STARTED")
  workHistoryVerified    String   @default("NOT_STARTED")
  proRegVerified         String   @default("NOT_STARTED")
  refereeCheckStatus     String   @default("NOT_STARTED")
  policeVetStatus        String   @default("NOT_STARTED")
  interviewStatus        String   @default("NOT_STARTED")   // Admin-only
  riskAssessmentStatus   String   @default("NOT_STARTED")   // Admin-only

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  documents       NannyDocument[]
  enquiriesReceived Enquiry[]      @relation("EnquiriesReceived")
  reviewsReceived   Review[]       @relation("ReviewsReceived")

  @@map("nanny_profiles")
}

// ============================================================
// Nanny Documents
// ============================================================

model NannyDocument {
  id              String   @id @default(cuid())
  nannyProfileId  String
  nannyProfile    NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  documentType    String   // ID, REFERENCES, FIRST_AID_CERT, POLICE_VET, TEACHER_REGISTRATION, WORK_HISTORY, PROFESSIONAL_REGISTRATION, REFEREE_LETTER
  fileName        String
  fileUrl         String?
  reviewStatus    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime @default(now())

  @@map("nanny_documents")
}

// ============================================================
// Job Posts
// ============================================================

model JobPost {
  id               String   @id @default(cuid())
  parentId         String
  parent           User     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  title            String
  suburb           String
  careType         String
  daysRequired     String
  childCount       Int
  childAges        String
  startDate        String
  hourlyBudget     Int
  specialistSupport String  @default("")
  description      String
  status           String   @default("PENDING") // PENDING, APPROVED, CLOSED, REJECTED
  contactEmail     String
  contactPhone     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("job_posts")
}

// ============================================================
// Enquiries
// ============================================================

model Enquiry {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("EnquiriesSent", fields: [parentId], references: [id], onDelete: Cascade)
  nannyId   String
  nanny     NannyProfile @relation("EnquiriesReceived", fields: [nannyId], references: [id], onDelete: Cascade)
  message   String
  status    String   @default("NEW") // NEW, CONTACTED, MATCHED, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("enquiries")
}

// ============================================================
// Reviews (placeholder for Phase 2)
// ============================================================

model Review {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("ReviewsGiven", fields: [parentId], references: [id], onDelete: Cascade)
  nannyId   String
  nanny     NannyProfile @relation("ReviewsReceived", fields: [nannyId], references: [id], onDelete: Cascade)
  rating    Int      @default(5)
  comment   String
  createdAt DateTime @default(now())

  @@map("reviews")
}

// ============================================================
// Skill Tags (for nanny specialisations)
// ============================================================

model SkillTag {
  id       String @id @default(cuid())
  name     String @unique
  category String @default("general") // general, specialist, qualification

  @@map("skill_tags")
}
