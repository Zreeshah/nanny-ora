// Prisma Schema for NannyOra
// Vercel Postgres (Neon-backed PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooled (pgbouncer) — runtime queries
  directUrl = env("DIRECT_URL")     // direct — migrations / db push
}

// ============================================================
// User & Auth
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("PARENT") // PARENT, NANNY, ADMIN
  image         String?
  // Password reset (single active token; SHA-256 hash only, never the raw token)
  resetTokenHash   String?
  resetTokenExpiry DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  parentProfile  ParentProfile?
  nannyProfile   NannyProfile?
  jobPosts       JobPost[]
  enquiriesSent  Enquiry[]      @relation("EnquiriesSent")
  reviewsGiven   Review[]       @relation("ReviewsGiven")
  favourites     Favourite[]    @relation("FavouritesByParent")
  profileViews   ProfileView[]  @relation("ViewsByUser")
  messagesSent   Message[]      @relation("MessagesSent")
  conversationReads ConversationRead[] @relation("ConversationReads")

  @@map("users")
}

// ============================================================
// Parent Profile
// ============================================================

model ParentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  suburb         String
  childAgeRange  String   // JSON array stored as string
  careTypeNeeded String   // JSON array stored as string
  preferredDays  String
  startDate      String?
  specialistNeeds String  @default("")
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("parent_profiles")
}

// ============================================================
// Nanny Profile
// ============================================================

model NannyProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  suburb                 String
  areasCovered           String   // JSON array stored as string
  yearsExperience        Int
  careTypes              String   // JSON array stored as string
  qualifications         String   @default("") // JSON array stored as string
  eceExperience          Boolean  @default(false)
  neurodiverseExperience Boolean  @default(false)
  firstAidCurrent        Boolean  @default(false)
  driverLicence          Boolean  @default(false)
  hourlyRate             Int
  bio                    String
  availabilitySummary    String   @default("")
  availability           String   @default("[]") // JSON array stored as string
  specialistTags         String   @default("[]") // JSON array stored as string
  languages              String   @default("[]") // JSON array stored as string (LANGUAGE_TAGS values)
  verificationLevel      String   @default("LISTED") // LISTED, VERIFIED, PREMIUM_VETTED, SPECIALIST
  adminStatus            String   @default("SUBMITTED") // DRAFT, SUBMITTED, UNDER_REVIEW, APPROVED, VERIFIED, SPECIALIST, SUSPENDED, ARCHIVED
  profileImageUrl        String?

  // Referee structured data (JSON array of {name, phone, email, relationship})
  refereeData            String   @default("[]")

  // --- 7 Safety Vetting Check Statuses ---
  // Values: NOT_STARTED, SUBMITTED, VERIFIED, REJECTED
  identityVerified       String   @default("NOT_STARTED")
  workHistoryVerified    String   @default("NOT_STARTED")
  proRegVerified         String   @default("NOT_STARTED")
  refereeCheckStatus     String   @default("NOT_STARTED")
  policeVetStatus        String   @default("NOT_STARTED")
  interviewStatus        String   @default("NOT_STARTED")   // Admin-only
  riskAssessmentStatus   String   @default("NOT_STARTED")   // Admin-only

  // Police vetting authorization (Children's Act 2014 consent)
  policeVetAuthorized     Boolean  @default(false)
  policeVetAuthorizedAt   DateTime?

  // --- Placement / availability (admin-managed; orthogonal to adminStatus & verificationLevel) ---
  placementStatus        String   @default("AVAILABLE") // AVAILABLE, TRIAL_PENDING, PLACED, CONTRACT_ENDING
  trialDate              String?  // date-input string, for TRIAL_PENDING
  placementStart         String?  // job start, for PLACED
  placementEnd           String?  // contract end / available-from, for CONTRACT_ENDING
  placementNote          String?  // admin-written public summary of the placement/job
  paidConfirmed          Boolean  @default(false) // admin-manual payment flag — INTERNAL, never public

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  documents       NannyDocument[]
  enquiriesReceived Enquiry[]      @relation("EnquiriesReceived")
  reviewsReceived   Review[]       @relation("ReviewsReceived")
  favouritedBy      Favourite[]    @relation("FavouritesOfNanny")
  views             ProfileView[]  @relation("ViewsOfNanny")
  jobApplications   JobApplication[]

  @@map("nanny_profiles")
}

// ============================================================
// Nanny Documents
// ============================================================

model NannyDocument {
  id              String   @id @default(cuid())
  nannyProfileId  String
  nannyProfile    NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  documentType    String   // ID, REFERENCES, FIRST_AID_CERT, POLICE_VET, TEACHER_REGISTRATION, WORK_HISTORY, PROFESSIONAL_REGISTRATION, REFEREE_LETTER
  fileName        String
  fileUrl         String?
  reviewStatus    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime @default(now())

  @@map("nanny_documents")
}

// ============================================================
// Job Posts
// ============================================================

model JobPost {
  id               String   @id @default(cuid())
  parentId         String
  parent           User     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  title            String
  suburb           String
  careType         String
  daysRequired     String
  childCount       Int
  childAges        String
  startDate        String
  hourlyBudget     Int
  specialistSupport String  @default("")
  description      String
  status           String   @default("PENDING") // PENDING, APPROVED, CLOSED, REJECTED
  contactEmail     String
  contactPhone     String?
  applications     JobApplication[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("job_posts")
}

// ============================================================
// Enquiries
// ============================================================

model Enquiry {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("EnquiriesSent", fields: [parentId], references: [id], onDelete: Cascade)
  nannyId   String
  nanny     NannyProfile @relation("EnquiriesReceived", fields: [nannyId], references: [id], onDelete: Cascade)
  message   String       // the parent's first message (seed of the conversation thread)
  flagged   Boolean  @default(false) // seed message contains contact info (email/phone)
  contactEmail String?  // admin-only visibility — never exposed to the nanny
  contactPhone String?  // admin-only visibility
  status    String   @default("NEW") // NEW, CONTACTED, MATCHED, CLOSED
  messages  Message[]
  reads     ConversationRead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // bumped on each new message → "last activity"

  @@map("enquiries")
}

// ============================================================
// Messages (two-way chat within an Enquiry thread)
// ============================================================

// Per-user read marker for a conversation (unread counts)
model ConversationRead {
  id         String   @id @default(cuid())
  enquiryId  String
  enquiry    Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("ConversationReads", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([enquiryId, userId])
  @@map("conversation_reads")
}

// A nanny's one-click application to an approved job post
model JobApplication {
  id             String       @id @default(cuid())
  jobId          String
  job            JobPost      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  nannyProfileId String
  nanny          NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  status         String       @default("PENDING") // PENDING, ACCEPTED, DECLINED (admin-managed later)
  createdAt      DateTime     @default(now())

  @@unique([jobId, nannyProfileId])
  @@map("job_applications")
}

model Message {
  id        String   @id @default(cuid())
  enquiryId String
  enquiry   Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  flagged   Boolean  @default(false) // contains contact info (email/phone)
  createdAt DateTime @default(now())

  @@index([enquiryId])
  @@map("messages")
}

// ============================================================
// Reviews (placeholder for Phase 2)
// ============================================================

model Review {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("ReviewsGiven", fields: [parentId], references: [id], onDelete: Cascade)
  nannyId   String
  nanny     NannyProfile @relation("ReviewsReceived", fields: [nannyId], references: [id], onDelete: Cascade)
  rating    Int      @default(5)
  comment   String
  createdAt DateTime @default(now())

  @@unique([parentId, nannyId])
  @@map("reviews")
}

// ============================================================
// Skill Tags (for nanny specialisations)
// ============================================================

model SkillTag {
  id       String @id @default(cuid())
  name     String @unique
  category String @default("general") // general, specialist, qualification

  @@map("skill_tags")
}

// ============================================================
// Favourites (parents saving nannies) + Profile Views tracking
// ============================================================

model Favourite {
  id        String       @id @default(cuid())
  parentId  String
  parent    User         @relation("FavouritesByParent", fields: [parentId], references: [id], onDelete: Cascade)
  nannyId   String
  nanny     NannyProfile @relation("FavouritesOfNanny", fields: [nannyId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([parentId, nannyId])
  @@map("favourites")
}

model ProfileView {
  id        String       @id @default(cuid())
  nannyId   String
  nanny     NannyProfile @relation("ViewsOfNanny", fields: [nannyId], references: [id], onDelete: Cascade)
  viewerId  String?
  viewer    User?        @relation("ViewsByUser", fields: [viewerId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())

  @@index([nannyId])
  @@index([viewerId])
  @@map("profile_views")
}
