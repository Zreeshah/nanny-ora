# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# netlify (moving to Vercel — keep local cruft out of git)
.netlify
netlify.toml

# local IDE / scratch files
Library
scratch_*.py
replace-purple.js
*.bak

# prisma local sqlite (schema provider is postgresql)
prisma/dev.db
prisma/dev.db-journal

# deno lockfile (project uses npm)
deno.lock

# typescript
*.tsbuildinfo
next-env.d.ts
